.version 9.0
.target sm_120
.address_size 64

.visible .entry histogram(
    .param .u64 hist, .param .u64 data, .param .s32 n)
{
    .reg .b32 %r<19>;
    .reg .b64 %rd<21>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [hist];
    ld.param.u64 %rd1, [data];
    ld.param.s32 %r2, [n];
    mov.u32 %r4, %tid.x;
    mov.u32 %r5, %ctaid.x;
    mov.u32 %r6, %ntid.x;
    mul.lo.s32 %r7, %r5, %r6;
    add.s32 %r8, %r4, %r7;
    setp.lt.s32 %p0, %r8, %r2;
    @%p0 bra if_true_2;
    bra if_false_3;
if_true_2:
    shl.b32 %r11, %r8, 2;
    cvt.u64.u32 %rd19, %r11;
    add.u64 %rd12, %rd1, %rd19;
    ld.global.u32 %r13, [%rd12];
    and.b32 %r14, %r13, 255;
    shl.b32 %r15, %r14, 2;
    cvt.u64.u32 %rd20, %r15;
    add.u64 %rd16, %rd0, %rd20;
    ld.global.s32 %r17, [%rd16];
    add.s32 %r18, %r17, 1;
    st.global.s32 [%rd16], %r18;
    bra if_merge_4;
if_false_3:
    bra if_merge_4;
if_merge_4:
    ret;
}
