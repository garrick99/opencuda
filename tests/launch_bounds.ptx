.version 9.0
.target sm_120
.address_size 64

.visible .entry bounded_kernel(
    .param .u64 out, .param .u64 in, .param .s32 n)
{
    .reg .f32 %f<16>;
    .reg .b32 %r<11>;
    .reg .b64 %rd<18>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [out];
    ld.param.u64 %rd1, [in];
    ld.param.s32 %r2, [n];
    mov.u32 %r4, %tid.x;
    mov.u32 %r5, %ctaid.x;
    mov.u32 %r6, %ntid.x;
    mul.lo.s32 %r7, %r5, %r6;
    add.s32 %r8, %r4, %r7;
    setp.lt.s32 %p0, %r8, %r2;
    @%p0 bra if_true_2;
    bra if_false_3;
if_true_2:
    shl.b32 %r10, %r8, 2;
    cvt.u64.u32 %rd16, %r10;
    add.u64 %rd11, %rd0, %rd16;
    cvt.u64.u32 %rd17, %r10;
    add.u64 %rd13, %rd1, %rd17;
    ld.global.f32 %f14, [%rd13];
    add.f32 %f15, %f14, 0f3F800000;
    st.global.f32 [%rd11], %f15;
    bra if_merge_4;
if_false_3:
    bra if_merge_4;
if_merge_4:
    ret;
}
