.version 9.0
.target sm_120
.address_size 64

.visible .entry sum_reduce(
    .param .u64 out, .param .u64 in, .param .s32 n)
{
    .reg .f32 %f<10>;
    .reg .b32 %r<12>;
    .reg .b64 %rd<15>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [out];
    ld.param.u64 %rd1, [in];
    ld.param.s32 %r2, [n];
    add.f32 %f3, 0f00000000, 0f00000000;
    add.s32 %r4, 0, 0;
    bra for_cond_2;
for_cond_2:
    setp.lt.s32 %p0, %r4, %r2;
    @%p0 bra for_body_3;
    bra for_exit_5;
for_body_3:
    shl.b32 %r6, %r4, 2;
    cvt.u64.u32 %rd13, %r6;
    add.u64 %rd7, %rd1, %rd13;
    ld.global.f32 %f8, [%rd7];
    add.f32 %f9, %f3, %f8;
    bra for_inc_4;
for_inc_4:
    add.s32 %r10, %r4, 1;
    add.f32 %f3, %f9, 0f00000000;
    add.s32 %r4, %r10, 0;
    bra for_cond_2;
for_exit_5:
    add.s32 %r11, 0, 0;
    cvt.u64.u32 %rd14, %r11;
    add.u64 %rd12, %rd0, %rd14;
    st.global.f32 [%rd12], %f3;
    ret;
}
