.version 9.0
.target sm_120
.address_size 64

.visible .entry cast_ops(
    .param .u64 fout, .param .u64 iout, .param .u64 fin, .param .u64 iin, .param .s32 n)
{
    .reg .f32 %f<22>;
    .reg .b32 %r<19>;
    .reg .b64 %rd<26>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [fout];
    ld.param.u64 %rd1, [iout];
    ld.param.u64 %rd2, [fin];
    ld.param.u64 %rd3, [iin];
    ld.param.s32 %r4, [n];
    mov.u32 %r6, %tid.x;
    setp.lt.s32 %p0, %r6, %r4;
    @%p0 bra if_true_2;
    bra if_false_3;
if_true_2:
    shl.b32 %r9, %r6, 2;
    cvt.u64.u32 %rd22, %r9;
    add.u64 %rd10, %rd2, %rd22;
    ld.global.f32 %f11, [%rd10];
    cvt.u64.u32 %rd23, %r9;
    add.u64 %rd14, %rd3, %rd23;
    ld.global.s32 %r15, [%rd14];
    cvt.u64.u32 %rd24, %r9;
    add.u64 %rd17, %rd1, %rd24;
    st.global.s32 [%rd17], %r18;
    cvt.u64.u32 %rd25, %r9;
    add.u64 %rd20, %rd0, %rd25;
    st.global.f32 [%rd20], %f21;
    bra if_merge_4;
if_false_3:
    bra if_merge_4;
if_merge_4:
    ret;
}
