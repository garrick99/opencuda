.version 9.0
.target sm_120
.address_size 64

.visible .entry negation(
    .param .u64 out, .param .u64 in, .param .s32 n)
{
    .reg .f32 %f<13>;
    .reg .b32 %r<8>;
    .reg .b64 %rd<15>;
    .reg .pred %p<1>;

entry_1:
    ld.param.u64 %rd0, [out];
    ld.param.u64 %rd1, [in];
    ld.param.s32 %r2, [n];
    mov.u32 %r4, %tid.x;
    setp.lt.s32 %p0, %r4, %r2;
    @%p0 bra if_true_2;
    bra if_false_3;
if_true_2:
    shl.b32 %r7, %r4, 2;
    cvt.u64.u32 %rd13, %r7;
    add.u64 %rd8, %rd1, %rd13;
    ld.global.f32 %f9, [%rd8];
    cvt.u64.u32 %rd14, %r7;
    add.u64 %rd11, %rd0, %rd14;
    sub.f32 %f12, 0f00000000, %f9;
    st.global.f32 [%rd11], %f12;
    bra if_merge_4;
if_false_3:
    bra if_merge_4;
if_merge_4:
    ret;
}
